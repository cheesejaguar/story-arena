# Postgres connection string. In production this is provisioned by the Neon
# Vercel Marketplace integration.
DATABASE_URL=

# Upstash Redis REST endpoint + token. Provisioned by the Upstash Vercel
# Marketplace integration under the legacy Vercel KV names (KV_REST_API_*).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# AI Gateway auth: VERCEL_OIDC_TOKEN is auto-injected on Vercel and auto-rotated.
# For local dev, run `vercel env pull` — it writes a short-lived OIDC token here.
VERCEL_OIDC_TOKEN=

# Long random secrets (>= 32 chars). Generate with: openssl rand -hex 32
ADMIN_SECRET=
SESSION_COOKIE_SECRET=

# System prompt version tag — used to invalidate cached generations when the
# system prompt changes.
SYSTEM_PROMPT_VERSION=v1
